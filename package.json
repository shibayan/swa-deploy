{
  "name": "swa-deploy",
  "description": "GitHub Action to deploy prebuilt assets to Azure Static Web Apps",
  "version": "1.2.0",
  "author": "shibayan",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/shibayan/swa-deploy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shibayan/swa-deploy.git"
  },
  "bugs": {
    "url": "https://github.com/shibayan/swa-deploy/issues"
  },
  "keywords": [
    "actions",
    "azure",
    "static-web-apps"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rimraf ./dist && npx rolldown --config rolldown.config.ts",
    "package:watch": "npm run package -- --watch",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "6.0.0",
    "@actions/core": "3.0.0",
    "@azure/arm-appservice": "18.0.0",
    "@azure/arm-resources-subscriptions": "2.1.0",
    "@azure/identity": "4.13.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@github/local-action": "7.0.1",
    "@jest/globals": "30.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "cross-env": "10.1.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "make-coverage-badge": "1.2.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rolldown": "1.0.0-rc.13",
    "ts-jest": "29.4.9",
    "ts-jest-resolver": "2.0.1",
    "typescript": "6.0.2"
  }
}
